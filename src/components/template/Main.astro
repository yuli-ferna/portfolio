---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import Home from "./Home.astro";
import Experience from "./Experience.astro";
import Education from "./Education.astro";
import Skills from "./Skills.astro";
import Projects from "./Projects.astro";
import Contact from "./Contact.astro";
import { easeInOut, motion } from "motion/react";

const sections = [
  { id: "home",       component: Home },
  { id: "skills",     component: Skills },
  { id: "experience", component: Experience },
  // { id: "experience",   component: Projects },
  { id: "education",  component: Education },
  { id: "contact",    component: Contact },
];

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<main class="">
  {sections.map((section, index) => (
  <section
    id={section.id}
    class={`flex flex-col items-center justify-center text-center
      ${section.accent
        ? "projects-bg"
        : (index + 1) % 2 === 0 ? "bg-container-item/10" : ""
      }`}
  >
    <motion.div client:load>
      <section.component t={t} />
    </motion.div>
  </section>
  ))}
</main>

<style>
  .projects-bg {
    background: linear-gradient(
      160deg,
      var(--color-pink-950) 0%,
      var(--color-falcon-800) 50%,
      var(--color-pink-950) 100%
    );
  }

  :root .projects-bg {
    background: linear-gradient(
      160deg,
      var(--color-falcon-300) 0%,
      var(--color-falcon-400) 50%,
      var(--color-falcon-300) 100%
    );
  }

  [data-theme="dark"] .projects-bg {
    background: linear-gradient(
      160deg,
      var(--color-pink-950) 0%,
      var(--color-falcon-800) 50%,
      var(--color-pink-950) 100%
    );
  }
</style>
