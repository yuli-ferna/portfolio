---
// ProjectsSection.astro
// Place this component below your Experience section
import { motion } from "motion/react";
---

<section class="projects-section">
  <div class="section-header">
    <span class="pixel-sparkle">✦</span>
    <h2>Proyectos & Demos</h2>
    <span class="pixel-sparkle">✦</span>
  </div>

  <p class="section-desc">
    Una selección de proyectos donde aplico mis conocimientos para crear soluciones funcionales e innovadoras.
  </p>

  <div class="monitor-wrapper">
    <!-- Monitor body -->
    <div class="monitor">
      <div class="monitor-top-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="monitor-title">yuli-ferna.github.io</span>
      </div>
      <div class="screen">
        <motion.iframe
          initial={{ opacity: 0 }}
          whileInView={{ opacity: 1 }}
          transition={{ duration: 0.5 }}
          src="https://yuli-ferna.github.io/"
          title="Proyectos y Demos de yuli-ferna"
          loading="lazy"
          scrolling="yes"
        ></motion.iframe>
        <div class="screen-glare"></div>
      </div>
    </div>
    <!-- Monitor stand -->
    <div class="monitor-neck"></div>
    <div class="monitor-base"></div>

    <!-- Pixel decorations -->
    <span class="deco deco-star1">✦</span>
    <span class="deco deco-star2">✧</span>
    <span class="deco deco-floppy">💾</span>
  </div>

  <a
    href="https://yuli-ferna.github.io/"
    target="_blank"
    rel="noopener noreferrer"
    class="pixel-btn"
  >
    <span class="btn-icon">🖥️</span>
    Ver todos mis proyectos
    <span class="btn-arrow">→</span>
  </a>
</section>

<style>
  .projects-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 3rem 1rem 4rem;
    font-family: 'Courier New', monospace;
  }

  /* ── Header ── */
  .section-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-header h2 {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin: 0;
    /* Use whatever heading color/font your portfolio uses */
  }

  .pixel-sparkle {
    color: #f9a8d4; /* pink-300 */
    font-size: 1.2rem;
    animation: sparkle 2s ease-in-out infinite alternate;
  }

  .pixel-sparkle:last-child {
    animation-delay: 0.6s;
  }

  @keyframes sparkle {
    from { opacity: 0.4; transform: scale(0.9) rotate(-10deg); }
    to   { opacity: 1;   transform: scale(1.2) rotate(10deg); }
  }

  .section-desc {
    max-width: 480px;
    text-align: center;
    font-size: 0.92rem;
    line-height: 1.7;
    opacity: 0.75;
    margin: 0;
  }

  /* ── Monitor wrapper ── */
  .monitor-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Floating pixel decorations */
  .deco {
    position: absolute;
    pointer-events: none;
    font-size: 1.4rem;
    animation: float 3s ease-in-out infinite;
  }

  .deco-star1 { top: -1rem; left: -2rem; color: #f9a8d4; animation-delay: 0s; }
  .deco-star2 { top: 2rem;  right: -2rem; color: #a5f3fc; animation-delay: 1s; font-size: 1rem; }
  .deco-floppy { bottom: 4rem; right: -2.5rem; animation-delay: 0.5s; }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50%       { transform: translateY(-8px) rotate(5deg); }
  }

  /* ── Monitor frame ── */
  .monitor {
    width: min(520px, 92vw);
    background: #fce7f3; /* pastel pink */
    border: 3px solid #374151;
    border-radius: 12px 12px 4px 4px;
    box-shadow:
      4px 4px 0 #374151,   /* pixel drop shadow */
      inset 0 0 0 2px #fdf2f8;
    overflow: hidden;
    image-rendering: pixelated;
  }

  /* Top bar (fake browser chrome) */
  .monitor-top-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: #fbcfe8;
    border-bottom: 2px solid #374151;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid #374151;
    display: inline-block;
  }
  .dot.red    { background: #fca5a5; }
  .dot.yellow { background: #fde68a; }
  .dot.green  { background: #bbf7d0; }

  .monitor-title {
    flex: 1;
    text-align: center;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: #374151;
    opacity: 0.7;
    margin-right: 1.5rem; /* optical balance vs dots */
  }

  /* Screen / iframe area */
  .screen {
    position: relative;
    width: 100%;
    height: 340px;
    background: #0f172a;
    overflow: hidden;
  }

  .screen iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    /* Scale down the page to fit nicely */
    transform: scale(0.75);
    transform-origin: top left;
    width: 133.33%;
    height: 133.33%;
    pointer-events: auto;
  }

  /* Subtle glare overlay */
  .screen-glare {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255,255,255,0.08) 0%,
      transparent 50%
    );
    pointer-events: none;
    border-radius: 0 0 4px 4px;
  }

  /* ── Stand ── */
  .monitor-neck {
    width: 28px;
    height: 24px;
    background: #fbcfe8;
    border-left: 3px solid #374151;
    border-right: 3px solid #374151;
    border-bottom: 3px solid #374151;
  }

  .monitor-base {
    width: 140px;
    height: 14px;
    background: #fce7f3;
    border: 3px solid #374151;
    border-radius: 0 0 8px 8px;
    box-shadow: 3px 3px 0 #374151;
  }

  /* ── Pixel button ── */
  .pixel-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.5rem;
    padding: 0.7rem 1.4rem;
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #374151;
    background: #fde68a; /* yellow, like the button in the screenshot */
    border: 2px solid #374151;
    border-radius: 4px;
    box-shadow: 3px 3px 0 #374151;
    text-decoration: none;
    transition: transform 0.1s, box-shadow 0.1s;
    cursor: pointer;
  }

  .pixel-btn:hover {
    transform: translate(-1px, -1px);
    box-shadow: 4px 4px 0 #374151;
  }

  .pixel-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 #374151;
  }

  .btn-arrow {
    transition: transform 0.2s;
  }

  .pixel-btn:hover .btn-arrow {
    transform: translateX(4px);
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .monitor { width: 95vw; }
    .screen  { height: 260px; }
  }
</style>
