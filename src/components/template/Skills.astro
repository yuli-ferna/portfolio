---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import DragConstraints from "../molecules/SkillDrag";
import SkillsIcon from "../atoms/icons/SkillsIcon";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const skills = t("skills") ?? {};
const skillsList = skills["skillsList"];
---

<div class="w-full min-h-screen flex flex-col items-center justify-center relative skills-section pt-50 pb-50">
  <div class="flex flex-row gap-4 mb-10 relative">
    <h1 class="title mb-6">{skills["title"]}</h1>
    <div class="absolute -top-5 -right-6 md:static">
      <SkillsIcon client:visible />
    </div>
  </div>
  <div class="md:max-w-150 text-lg px-3 md:px-0">{skills["description"]}</div>
  <div class="mt-17">
    <DragConstraints skills={skills} skillsList={skillsList} client:only="react" />
  </div>
</div>
